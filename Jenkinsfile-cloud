pipeline {
    agent {label 'jenkins-agent2'}

    parameters {
        string(name: 'BRANCH', defaultValue: 'main', description: 'Git branch to build and deploy')
    }

    stages {
        stage('Setup Environment Files') {
            steps {
                withCredentials([
                    file(credentialsId: 'env.pi', variable: 'ENV_PI_FILE'),
                    file(credentialsId: 'env.pi2', variable: 'ENV_PI2_FILE')
                ]) {
                    sh '''
                        rm -f env.pi env.pi2
                        cp $ENV_PI_FILE ./env.pi
                        cp $ENV_PI2_FILE ./env.pi2
                        chmod 644 env.pi env.pi2
                    '''
                }
            }
        }

        stage('Sync Host Repo') {
            steps {
                sh '''
                    . ./env.pi2
                    ssh -i /home/jenkins/.ssh/id_rsa -o StrictHostKeyChecking=no strider@$PI2_IP "cd ~/adventuretube-microservice && git checkout -- . && git pull"
                '''
            }
        }

        stage('Build Maven & Docker Images') {
            steps {
                sh "./adventuretube-cloud-create-dockerimage.sh pi2 \"${params.BRANCH}\""
            }
        }

        stage('Import Images to K3s') {
            steps {
                sh '''
                    . ./env.pi2
                    echo "Importing Docker images into K3s containerd on PI2..."
                    ssh -i /home/jenkins/.ssh/id_rsa -o StrictHostKeyChecking=no strider@$PI2_IP "docker save adventuretube-microservice-eureka-server:latest | sudo k3s ctr images import -"
                    ssh -i /home/jenkins/.ssh/id_rsa -o StrictHostKeyChecking=no strider@$PI2_IP "docker save adventuretube-microservice-config-service:latest | sudo k3s ctr images import -"
                    ssh -i /home/jenkins/.ssh/id_rsa -o StrictHostKeyChecking=no strider@$PI2_IP "docker save adventuretube-microservice-gateway-service:latest | sudo k3s ctr images import -"
                    echo "PI2 K3s image import completed."
                    echo "Note: PI1 image sync skipped in pipeline (too heavy for Jenkins agent). Run manually if needed:"
                    echo "  ssh strider@PI2 'docker save <image>:latest' | ssh strider@PI1 'sudo k3s ctr images import -'"
                '''
            }
        }

        stage('Deploy to K3s') {
            steps {
                sh '''
                    . ./env.pi2
                    echo "Deploying to K3s via PI1 control plane..."
                    ssh -i /home/jenkins/.ssh/id_rsa -o StrictHostKeyChecking=no strider@$PI1_IP "sudo kubectl apply --validate=false -f -" < k8s/cloud-services.yaml
                    ssh -i /home/jenkins/.ssh/id_rsa -o StrictHostKeyChecking=no strider@$PI1_IP "sudo kubectl rollout restart deployment/eureka-server deployment/config-service deployment/gateway-service"
                '''
            }
        }

        stage('Check K3s Pod Health') {
            steps {
                script {
                    def services = ["eureka-server", "config-service", "gateway-service"]

                    services.each { service ->
                        def serviceReady = false
                        for (int i = 0; i < 10; i++) {
                            def status = sh(
                                script: """
                                    . ./env.pi2
                                    ssh -i /home/jenkins/.ssh/id_rsa -o StrictHostKeyChecking=no strider@\$PI1_IP "sudo kubectl get deployment ${service} -o jsonpath='{.status.readyReplicas}'" || echo '0'
                                """,
                                returnStdout: true
                            ).trim()

                            if (status == '1') {
                                serviceReady = true
                                echo "${service} is ready."
                                break
                            }

                            echo "${service} is not ready yet (ready: ${status}). Retrying in 30 seconds..."
                            sleep(30)
                        }

                        if (!serviceReady) {
                            error("${service} did not become ready in the expected time")
                        }
                    }
                }
            }
        }
    }
}
