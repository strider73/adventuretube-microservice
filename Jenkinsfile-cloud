// Host-native pipeline: all heavy work runs on PI2 host via SSH
pipeline {
    agent {label 'jenkins-agent2'}

    parameters {
        string(name: 'BRANCH', defaultValue: 'main', description: 'Git branch to build and deploy')
    }

    environment {
        PI2_HOST = '192.168.1.105'
        PI1_HOST = '192.168.1.199'
        SSH_KEY  = '/home/jenkins/.ssh/id_rsa'
        SSH_OPTS = '-o StrictHostKeyChecking=no'
        REMOTE_DIR = '/home/strider/adventuretube-microservice'
        CLOUD_IMAGES = 'eureka-server config-service gateway-service'
    }

    stages {
        stage('Sync Host Repo') {
            steps {
                sh """
                    ssh -i ${SSH_KEY} ${SSH_OPTS} strider@${PI2_HOST} \
                        "cd ${REMOTE_DIR} && git checkout -- . && git fetch origin && git checkout ${params.BRANCH} && git pull origin ${params.BRANCH}"
                """
            }
        }

        stage('Setup Environment Files') {
            steps {
                withCredentials([
                    file(credentialsId: 'env.pi', variable: 'ENV_PI_FILE'),
                    file(credentialsId: 'env.pi2', variable: 'ENV_PI2_FILE')
                ]) {
                    sh """
                        scp -i ${SSH_KEY} ${SSH_OPTS} \$ENV_PI_FILE strider@${PI2_HOST}:${REMOTE_DIR}/env.pi
                        scp -i ${SSH_KEY} ${SSH_OPTS} \$ENV_PI2_FILE strider@${PI2_HOST}:${REMOTE_DIR}/env.pi2
                    """
                }
            }
        }

        stage('Build Maven & Docker Images') {
            steps {
                sh """
                    ssh -i ${SSH_KEY} ${SSH_OPTS} strider@${PI2_HOST} \
                        "cd ${REMOTE_DIR} && ./adventuretube-cloud-create-dockerimage.sh pi2 ${params.BRANCH}"
                """
            }
        }

        stage('Import Images to K3s') {
            steps {
                sh """
                    echo "Importing Docker images into K3s containerd on PI2..."
                    for IMAGE in ${CLOUD_IMAGES}; do
                        echo "  Importing adventuretube-microservice-\${IMAGE}:latest on PI2..."
                        ssh -i ${SSH_KEY} ${SSH_OPTS} strider@${PI2_HOST} \
                            "docker save adventuretube-microservice-\${IMAGE}:latest | sudo k3s ctr images import -"
                        ssh -i ${SSH_KEY} ${SSH_OPTS} strider@${PI2_HOST} \
                            "sync && echo 3 | sudo tee /proc/sys/vm/drop_caches > /dev/null"
                    done

                    # PI1 transfer skipped — pods pinned to PI2 via nodeSelector
                    # Re-enable when PI2 has more RAM or Docker is replaced with nerdctl
                """
            }
        }

        stage('Deploy to K3s') {
            steps {
                sh """
                    echo "Deploying to K3s via PI1 control plane..."
                    ssh -i ${SSH_KEY} ${SSH_OPTS} strider@${PI2_HOST} "cat ${REMOTE_DIR}/k8s/cloud-services.yaml" \
                        | ssh -i ${SSH_KEY} ${SSH_OPTS} strider@${PI1_HOST} "sudo kubectl apply --validate=false -f - -n adventuretube"
                    ssh -i ${SSH_KEY} ${SSH_OPTS} strider@${PI1_HOST} \
                        "sudo kubectl rollout restart deployment/eureka-server deployment/config-service deployment/gateway-service -n adventuretube"
                """
            }
        }

        stage('Check K3s Pod Health') {
            steps {
                script {
                    def services = ["eureka-server", "config-service", "gateway-service"]

                    services.each { service ->
                        def serviceReady = false
                        for (int i = 0; i < 10; i++) {
                            def status = sh(
                                script: """
                                    ssh -i ${SSH_KEY} ${SSH_OPTS} strider@${PI1_HOST} \
                                        "sudo kubectl get deployment ${service} -n adventuretube -o jsonpath='{.status.readyReplicas}'" || echo '0'
                                """,
                                returnStdout: true
                            ).trim()

                            if (status == '1') {
                                serviceReady = true
                                echo "${service} is ready."
                                break
                            }

                            echo "${service} is not ready yet (ready: ${status}). Retrying in 30 seconds..."
                            sleep(30)
                        }

                        if (!serviceReady) {
                            error("${service} did not become ready in the expected time")
                        }
                    }
                }
            }
        }
    }
}
