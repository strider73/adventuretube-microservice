// Host-native pipeline: all heavy work runs on PI2 host via SSH.
// Images are built directly into K3s containerd via nerdctl (no save/import step).
pipeline {
    agent {label 'jenkins-agent2'}

    parameters {
        string(name: 'BRANCH', defaultValue: 'main', description: 'Git branch to build and deploy')
    }

    environment {
        PI2_HOST = '192.168.1.105'
        PI1_HOST = '192.168.1.199'
        SSH_KEY  = '/home/jenkins/.ssh/id_rsa'
        SSH_OPTS = '-o StrictHostKeyChecking=no'
        REMOTE_DIR = '/home/strider/adventuretube-microservice'
    }

    stages {
        stage('Sync Host Repo') {
            steps {
                sh """
                    ssh -i ${SSH_KEY} ${SSH_OPTS} strider@${PI2_HOST} \
                        "cd ${REMOTE_DIR} && git checkout -- . && git checkout ${params.BRANCH} && git pull origin ${params.BRANCH}"
                """
            }
        }

        stage('Setup Environment Files') {
            steps {
                withCredentials([
                    file(credentialsId: 'env.pi', variable: 'ENV_PI_FILE'),
                    file(credentialsId: 'env.pi2', variable: 'ENV_PI2_FILE')
                ]) {
                    sh """
                        scp -i ${SSH_KEY} ${SSH_OPTS} \$ENV_PI_FILE strider@${PI2_HOST}:${REMOTE_DIR}/env.pi
                        scp -i ${SSH_KEY} ${SSH_OPTS} \$ENV_PI2_FILE strider@${PI2_HOST}:${REMOTE_DIR}/env.pi2
                    """
                }
            }
        }

        stage('Build Images with nerdctl') {
            steps {
                sh """
                    ssh -i ${SSH_KEY} ${SSH_OPTS} strider@${PI2_HOST} \
                        "cd ${REMOTE_DIR} && ./adventuretube-service-create-dockerimage.sh pi2 ${params.BRANCH}"
                """
            }
        }

        stage('Deploy to K3s') {
            steps {
                sh """
                    echo "Deploying to K3s via PI1 control plane..."
                    ssh -i ${SSH_KEY} ${SSH_OPTS} strider@${PI2_HOST} "cat ${REMOTE_DIR}/k8s/adventure-services.yaml" \
                        | ssh -i ${SSH_KEY} ${SSH_OPTS} strider@${PI1_HOST} "sudo kubectl apply --validate=false -f - -n adventuretube"
                    ssh -i ${SSH_KEY} ${SSH_OPTS} strider@${PI1_HOST} \
                        "sudo kubectl rollout restart deployment/auth-service deployment/member-service deployment/web-service deployment/geospatial-service deployment/youtube-service -n adventuretube"
                """
            }
        }

        stage('Check K3s Pod Health') {
            steps {
                script {
                    def services = ["auth-service", "member-service", "web-service", "geospatial-service", "youtube-service"]

                    services.each { service ->
                        def serviceReady = false
                        for (int i = 0; i < 10; i++) {
                            def status = sh(
                                script: """
                                    ssh -i ${SSH_KEY} ${SSH_OPTS} strider@${PI1_HOST} \
                                        "sudo kubectl get deployment ${service} -n adventuretube -o jsonpath='{.status.readyReplicas}'" || echo '0'
                                """,
                                returnStdout: true
                            ).trim()

                            if (status == '1') {
                                serviceReady = true
                                echo "${service} is ready."
                                break
                            }

                            echo "${service} is not ready yet (ready: ${status}). Retrying in 30 seconds..."
                            sleep(30)
                        }

                        if (!serviceReady) {
                            error("${service} did not become ready in the expected time")
                        }
                    }
                }
            }
        }
    }
}
